{
    "compilerOptions": {
        "outDir": "bin",
        "target": "ES2020",
        "module": "commonjs",
        "moduleResolution": "node",
        "declaration": true,
        "sourceMap": true,
        "stripInternal": true,
        "experimentalDecorators": true,
        "noFallthroughCasesInSwitch": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true,
        "types": ["node"],
        "typeRoots": ["./node_modules/@types"]
    },
    "files": [
        "billingMeter.ts",
        "config/index.ts",
        "config/vars.ts",
        "coupon.ts",
        "customer.ts",
        "entitlementsFeature.ts",
        "getBillingMeter.ts",
        "index.ts",
        "price.ts",
        "product.ts",
        "promotionCode.ts",
        "provider.ts",
        "shippingRate.ts",
        "taxRate.ts",
        "types/index.ts",
        "types/input.ts",
        "types/output.ts",
        "utilities.ts",
        "v2billingLicenseFee.ts",
        "v2billingLicensedItem.ts",
        "v2billingMeteredItem.ts",
        "v2billingPricingPlan.ts",
        "v2billingPricingPlanComponent.ts",
        "v2billingRateCard.ts",
        "v2billingRateCardRate.ts",
        "v2billingServiceAction.ts",
        "v2coreEventDestination.ts",
        "webhookEndpoint.ts"
    ]
}
